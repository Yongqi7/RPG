            ]

        },
        {
            "name": "eval_track debugger",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tools/test.py",
            "console": "integratedTerminal",
            "args": [
                "./projects/configs/stage1_track_cooper/submodules_cooper_track.py",
                //"ckpts/epoch_6_track_fusion_ue5_full.pth",
                "ckpts/uniad_base_e2e.pth",
