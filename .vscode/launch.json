                "--eval", "bbox",

            ]
        },
        {
            "name": "2_eval submodule fusion track debugger",
            "type": "debugpy",
            "request": "launch",
            "program": "/bin/bash",
            //"program": "${workspaceFolder}/tools/uniad_dist_eval.sh",
            "console": "integratedTerminal",
            "args": [
                "${workspaceFolder}/tools/uniad_dist_eval.sh",
