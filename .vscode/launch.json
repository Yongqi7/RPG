            "name": "eval submodule fusion track map debugger",
            "type": "debugpy",
            "request": "launch",
            "module": "torch.distributed.launch",
            "console": "integratedTerminal",
            "args": [
                "--nproc_per_node=1",
                "--master_port=29500",
                "tools/test.py",
                "./projects/configs/submodule_fusion/submodules_cooper_track_map.py",
