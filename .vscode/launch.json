            "justMyCode": false,
            "env": {
                "CUDA_VISIBLE_DEVICES": "3",
                "PYTHONPATH": "${workspaceFolder}/../tools/Bench2DriveZoo:${env:PYTHONPATH}",
            }
        },
        {
            "name": "training submodule fusion track_map debugger",
