            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/cooper_uniad_visualization.py",
            "console": "integratedTerminal",
            "args": [
                "--root-dir", "./data/openv2v_4_cams",
                "--scene-name",
                "2021_08_23_16_06_26_243",
                "2021_08_23_16_06_26_252",
                "2021_08_23_16_06_26_261",
