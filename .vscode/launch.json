    "version": "0.2.0",
    "configurations": [
        {
            "name": "create data debugger",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tools/create_data.py",
            "console": "integratedTerminal",
            "args": [
                // "openv2v_4_cams",
                // "--root-path", "./data/openv2v_4_cams",
                // "--out-dir", "./data/infos_mini",
                // "--extra-tag", "openv2v_4_cams",
