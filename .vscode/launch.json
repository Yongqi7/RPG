            }
        },
        {
            "name": "eval submodule fusion track debugger",
            "type": "debugpy",
            "request": "launch",
            "module": "torch.distributed.launch",
            "console": "integratedTerminal",
            "args": [
                "--nproc_per_node=1",
                "--master_port=29500",
                "tools/test.py",
                "./projects/configs/submodule_fusion/submodules_e2e.py",
                "./ckpts/epoch_18_ref_pts_in_track_e2e.pth",
                "--launcher", "pytorch",
                "--out", "output/results_ref_pts_in_track_e2e.pkl",
                "--eval", "bbox"
            ],
            "env": {
                "CUDA_VISIBLE_DEVICES": "0"
            }
        }, 
