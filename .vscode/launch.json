                // "--canbus", "./data/openv2v_4_cams"
                "openv2v_4_cams",
                "--root-path", "./data/m3cad_carla_ue5",
                "--out-dir", "./data/infos",
                "--extra-tag", "m3cad_carla_ue5",
                "--version", "v1.0-mini",
                "--canbus", "./data/m3cad_carla_ue5"
            ]
        },
        {
            "name": "dataset_statistic",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tools/dataset_statistic.py",
            "console": "integratedTerminal",
            "args": [
                "./projects/configs/stage1_track/base_track.py",
            ],
            "justMyCode": false,
        },
        {
            "name": "training track debugger",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tools/train.py",
            "console": "integratedTerminal",
            "args": [
                "./projects/configs/stage1_track/base_track.py",
                "--gpus", "1",
            ],
            "justMyCode": false,
            "env": {
                "CUDA_VISIBLE_DEVICES": "0"
            }
        },
        {
            "name": "training submodule fusion track debugger",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tools/train.py",
            "console": "integratedTerminal",
            "args": [
                "./projects/configs/submodule_fusion/submodules_cooper_track.py",
